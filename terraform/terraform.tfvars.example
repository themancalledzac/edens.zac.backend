# =============================================================================
# Terraform Variables -- Portfolio Backend
# =============================================================================
# Copy this file to terraform.tfvars and fill in your real values:
#   cp terraform.tfvars.example terraform.tfvars
#
# IMPORTANT: terraform.tfvars is in .gitignore and must NEVER be committed.
# =============================================================================

# AWS region (default: us-west-2)
# aws_region = "us-west-2"

# EC2 instance type (default: t3.small)
# instance_type = "t3.small"

# VPC ID where the EC2 instance lives
# Find in AWS console: VPC > Your VPCs
vpc_id = "vpc-0XXXXXXXXXXXX"

# Subnet ID to launch the EC2 instance into
# Find in AWS console: VPC > Subnets
subnet_id = "subnet-0XXXXXXXXXXXX"

# AMI ID for the EC2 instance
# Find in AWS console: EC2 > Instances > select instance > AMI ID
ec2_ami_id = "ami-0XXXXXXXXXXXX"

# Name of your existing EC2 key pair for SSH access
key_pair_name = "portfolio-backend-key"

# Your IP address in CIDR notation for SSH access
# Find your IP: curl ifconfig.me
# Example: "203.0.113.10/32"
ssh_allowed_cidr = "REPLACE_WITH_YOUR_IP/32"

# Name of your existing S3 bucket (format: your-domain.portfolio)
s3_bucket_name = "your-domain.portfolio"

# Project name used for tagging (default: "portfolio")
# project_name = "portfolio"

# Environment name (default: "production")
# environment = "production"
