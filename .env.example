# Spring Profile
# Use "dev" for local development, "prod" on EC2/production
SPRING_PROFILES_ACTIVE=prod

# PostgreSQL Configuration
# For local dev, open an SSH tunnel (scripts/db-tunnel.sh) and use POSTGRES_HOST=localhost.
# On EC2 the app reaches the database container on the shared Docker network / localhost.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=edens_zac
POSTGRES_USER=zedens
POSTGRES_PASSWORD=your_secure_password_here

# AWS Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_PORTFOLIO_S3_BUCKET=your_s3_bucket_name
AWS_CLOUDFRONT_DOMAIN=your_cloudfront_domain.cloudfront.net
# CloudFront distribution id (e.g. E1ABCDEFGHIJKL). Required for cache invalidation
# on image delete. If unset, deletes still succeed but stale-cached images may persist
# until CloudFront's TTL expires.
AWS_CLOUDFRONT_DISTRIBUTION_ID=

# Shared secret between the Next.js BFF proxy and the Spring backend.
# For production, generate with: openssl rand -hex 32
INTERNAL_API_SECRET=your_secure_secret_here

# Optional rotation candidate. During a secret rotation, set this to the new value
# while INTERNAL_API_SECRET still holds the old one; the backend accepts either.
# Once the BFF is fully cut over, promote it to INTERNAL_API_SECRET and clear this.
# Leave blank otherwise.
INTERNAL_API_SECRET_NEXT=

# Secret used to sign client-gallery HMAC access tokens. Required (no default in prod).
# Generate with: openssl rand -hex 32
ACCESS_TOKEN_SECRET=your_secure_access_token_secret_here

# Auth session + client-gallery cookies carry the Secure flag by default. The dev
# profile forces both to false so cookies work over plain http://localhost. Only set
# these if you run TLS locally.
AUTH_COOKIE_SECURE=true
GALLERY_COOKIE_SECURE=true

# WebAuthn (passkey) relying-party configuration. WEBAUTHN_RP_ID is the effective
# domain (no scheme/port). WEBAUTHN_ALLOWED_ORIGINS is a comma-separated list of full
# origins allowed to complete a passkey ceremony. Defaults target local dev.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Zac Edens Photography
WEBAUTHN_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Transactional email (AWS SES v2). Disabled by default — flip EMAIL_ENABLED to true
# once the SES domain + from-address are verified. EMAIL_FRONTEND_BASE_URL is the base
# used when building invite/gallery links in outbound email.
EMAIL_ENABLED=false
EMAIL_FROM_ADDRESS=no-reply@example.com
EMAIL_FRONTEND_BASE_URL=https://zacedens.com

# Photography directory mount for RAW file uploads (local dev only, not needed on EC2)
# PHOTOGRAPHY_PATH=/Users/yourname/Photography
# External drives root, so RAW files stored on external HDDs (/Volumes/<drive>/...) can be
# uploaded too. Local dev only; not needed on EC2. Usually just /Volumes on macOS.
# PHOTOGRAPHY_EXTERNAL_PATH=/Volumes

# JVM Memory (local dev defaults: -Xmx1g -Xms512m)
# EC2 prod only serves reads, so it needs less heap
JAVA_OPTS=-Xmx384m -Xms256m

# Docker container memory limit (local dev default: 1536M)
DOCKER_MEMORY_LIMIT=768M
