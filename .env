SPRING_PROFILES_ACTIVE=dev

# PostgreSQL Configuration (via SSH tunnel to EC2)
# Use host.docker.internal so the container reaches the tunnel on your Mac
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_DB=edens_zac
POSTGRES_USER=zedens
POSTGRES_PASSWORD=$POSTGRES_PASSWORD

# AWS Configuration
AWS_ACCESS_KEY_ID=$AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=$AWS_SECRET_ACCESS_KEY
AWS_PORTFOLIO_S3_BUCKET=$AWS_PORTFOLIO_S3_BUCKET
AWS_CLOUDFRONT_DOMAIN=$AWS_CLOUDFRONT_DOMAIN
PHOTOGRAPHY_PATH=/Users/themancalledzac/Photography
